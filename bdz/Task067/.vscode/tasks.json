{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C project",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-g",
        "${workspaceFolder}/main.c",
        "${workspaceFolder}/customstr.c",
        "-o",
        "${workspaceFolder}/main"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}